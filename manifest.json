{
  "manifest_version": 2,
  "name": "Pegmus",
  "version": "1.0",
  "description": "Pegmus é uma extensao para pegar musicas das playlist do youtube",
  "browser_action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_title": "Pegmus",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "64": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/playlist?list=*"
      ],
      "js": ["script.js"]
    }
  ]
}